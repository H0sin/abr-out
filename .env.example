# --- Telegram ---
BOT_TOKEN=

# --- Database ---
POSTGRES_USER=abrout
POSTGRES_PASSWORD=abrout
POSTGRES_DB=abrout
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- 3x-ui panel ---
XUI_BASE_URL=http://panel:54321
XUI_USERNAME=admin
XUI_PASSWORD=admin
XUI_PANEL_HOST_PUBLIC=panel.example.com  # what we tell sellers to tunnel to

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_INTERNAL_TOKEN=eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9
ADMIN_TELEGRAM_IDS=123456789

# --- Wallet & billing ---
COMMISSION_PCT=0.15
MIN_TOPUP_USD=2
TRAFFIC_POLL_INTERVAL_SEC=60
# Set to false to make the traffic poller skip the panel-side reset step
# (read-only diff mode — useful for debugging billing math).
TRAFFIC_RESET_ENABLED=true

# --- Payments (NowPayments crypto gateway) ---
# از داشبورد NowPayments → Store Settings کلید API را بگیر
NOWPAYMENTS_API_KEY=
# از داشبورد NowPayments → Store Settings → IPN, دکمه Generate IPN Secret
NOWPAYMENTS_IPN_SECRET=

# --- USDT-BSC Withdrawals (hot wallet on this server) ---
# RPC endpoint برای BSC. برای تست از https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_RPC_URL=https://bsc-dataseed1.binance.org
# کلید خصوصی هات‌والت BSC که USDT و BNB برای کارمزد در آن نگهداری می‌شود.
# خالی گذاشتن این فیلد عملاً قابلیت برداشت را غیرفعال می‌کند.
BSC_HOT_WALLET_PRIVATE_KEY=
# قرارداد USDT-BEP20 روی BSC mainnet — برای testnet مقدار قرارداد test را بگذار.
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
# حداقل مبلغ یک برداشت (USD).
WITHDRAWAL_MIN_USD=1
# سقف گس برای transfer در BEP20 — تقریباً 80,000 کافی است.
WITHDRAWAL_GAS_LIMIT=80000
# ضریب ایمنی روی تخمین کارمزد (1.20 یعنی +20%).
WITHDRAWAL_FEE_BUFFER_PCT=1.20
# قیمت BNB/USDT برای تبدیل کارمزد به دلار.
BNB_PRICE_FEED_URL=https://api.binance.com/api/v3/ticker/price?symbol=BNBUSDT

# --- Webhooks / Public URL ---
# دامنه‌ای که پشت Cloudflare به IP سرور وصل کردی — Caddy از این برای صدور گواهی TLS استفاده می‌کند
# و وب‌هوک‌های پابلیک هم خودکار از روی همین ساخته می‌شوند: https://${DOMAIN}/webhook/...
DOMAIN=iranesfahan.com
# اختیاری — فقط اگر می‌خواهی URL وب‌هوک متفاوت با https://${DOMAIN} باشد
# WEBHOOK_BASE_URL=

# --- Logging ---
LOG_LEVEL=INFO
