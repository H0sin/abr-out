# --- Webhooks / Public URL ---
# دامنه‌ای که پشت Cloudflare به IP سرور وصل کردی — Caddy از این برای صدور گواهی TLS استفاده می‌کند
# و وب‌هوک‌های پابلیک هم خودکار از روی همین ساخته می‌شوند: https://${DOMAIN}/webhook/...
DOMAIN=iranesfahan.com
# اختیاری — فقط اگر می‌خواهی URL وب‌هوک متفاوت با https://${DOMAIN} باشد
# WEBHOOK_BASE_URL=

# --- Logging ---
LOG_LEVEL=INFO
