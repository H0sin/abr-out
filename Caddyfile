# Caddy serves the public-facing surface behind Cloudflare.
# - DOMAIN must point to this server (Cloudflare A record).
# - Caddy auto-issues a Let's Encrypt cert via HTTP-01/TLS-ALPN.
# - With Cloudflare proxy ON: set Cloudflare SSL mode to "Full (strict)".
#
# Public surface:
#   /webhook/*  → 3rd-party payment webhooks
#   /health     → uptime monitors
#   /app/*      → React Telegram Mini App (static, served by FastAPI)
#   /api/*      → Mini App backend (initData-authenticated)
# Everything else is rejected; admin/prober endpoints stay on the docker net.

{
	# Setting an email enables BOTH Let's Encrypt and ZeroSSL as issuers.
	# If LE hits a rate limit, Caddy automatically falls back to ZeroSSL.
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip

	handle /webhook/* {
		reverse_proxy api:8000
	}

	handle /health {
		reverse_proxy api:8000
	}

	handle /app/* {
		reverse_proxy api:8000
	}

	# /app without trailing slash → redirect to /app/
	redir /app /app/ 308

	handle /api/* {
		reverse_proxy api:8000
	}

	handle {
		respond "Not Found" 404
	}
}
